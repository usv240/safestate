# ── SafeState environment ────────────────────────────────────────────
# Local development (default): point at a local Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/safestate

# ── Aurora DSQL (production) ──────────────────────────────────────────
# Set DSQL_ENDPOINT to switch the app to DSQL with IAM-token auth.
# Leave it EMPTY to keep using the local Postgres above.
DSQL_ENDPOINT=
DSQL_DATABASE=postgres
DSQL_USER=admin
AWS_REGION=us-east-1

# Second peered region (for the multi-region race demo)
DSQL_ENDPOINT_REGION_B=
AWS_REGION_B=us-east-2

DB_POOL_MAX=5

# ── DynamoDB activity firehose (optional; sane defaults in code) ──────
# Uses the same SAFESTATE_AWS_* credentials as DSQL on Vercel.
SAFESTATE_DDB_TABLE=safestate_events
SAFESTATE_DDB_REGION=us-east-1

# ── AI Match Assistant (Vercel AI SDK + Anthropic) ───────────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
